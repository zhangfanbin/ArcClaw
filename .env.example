# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Supported providers: openai | anthropic | ollama | deepseek
#
# --- DeepSeek via OpenAI-compatible API (recommended) ---
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-v4-pro
# LLM_MODEL_FAST=deepseek-v4-flash
#
# --- DeepSeek via Anthropic-compatible API ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-your-deepseek-key
# LLM_BASE_URL=https://api.deepseek.com/anthropic
# LLM_MODEL=deepseek-v4-pro
# LLM_MODEL_FAST=deepseek-v4-flash
#
# --- OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4o
#
# --- Anthropic ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# LLM_MODEL=claude-sonnet-4-20250514
#
# --- Ollama (local) ---
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3

LLM_PROVIDER=deepseek

# LLM Keys (set the one matching your provider)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
DEEPSEEK_API_KEY=sk-your-deepseek-key
OLLAMA_BASE_URL=http://localhost:11434

# LLM Model Configuration
# Primary model (used by Team Leader for orchestration/reasoning)
LLM_MODEL=deepseek-v4-pro
# Fast model (used by worker agents: PD, Frontend, Backend, QA)
LLM_MODEL_FAST=deepseek-v4-flash
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Optional: custom base URL for Anthropic or OpenAI providers
# LLM_BASE_URL=https://api.deepseek.com/anthropic
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Agent Configuration
AGENT_MAX_STEPS=15
AGENT_CONTEXT_TOKEN_BUDGET=100000
AGENT_CONCURRENT_TASKS=1

# API Server
API_PORT=3000
API_HOST=0.0.0.0

# Dashboard
DASHBOARD_PORT=5173

# Paths
DATA_DIR=./data
WORKSPACE_DIR=./workspaces
PROMPTS_DIR=./prompts
