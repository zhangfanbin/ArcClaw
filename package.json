{
  "name": "arcclaw",
  "version": "0.1.0",
  "description": "Multi-agent AI collaboration platform for end-to-end software delivery",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "arcclaw": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "prompts/",
    ".env.example",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "agents",
    "multi-agent",
    "llm",
    "software-delivery",
    "openai",
    "anthropic",
    "deepseek",
    "ollama",
    "task-management",
    "code-generation"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "start": "node dist/index.js",
    "dashboard": "npm run --prefix dashboard dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dashboard\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "ai": "^4.0.0",
    "chokidar": "^4.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "nanoid": "^5.0.0",
    "ollama-ai-provider": "^1.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "proper-lockfile": "^4.1.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
